(use "stdlib/basic" "stdlib/c" "stdlib/libnob")

(basic.open-namespace "basic")
(open-namespace "c")

(display "=========================================================\n")
(display "   lext Standard Libraries 100% Coverage Stress Test\n")
(display "=========================================================\n\n")

;; Compile helper library for FFI tests
(let ((cmd-args '("gcc" "-shared" "-fPIC" "test/test_lib.c" "-o" "test/libtest.so")))
  (if (libnob.cmd-run cmd-args)
      (display "[INIT] test/libtest.so compiled successfully.\n")
      (error "Failed to compile test/test_lib.c")))

(define libtest (ffi-open "./test/libtest.so"))
(define libc (ffi-open #f))

;; ============================================================================
;; PART A: basic.lext & c.lext coverage
;; ============================================================================
(display "\n--- [PART A] Testing basic.lext & c.lext ---\n")

;; 1. translate-ffi-type
(display (format #f "  translate-ffi-type (* char): ~S\n" (translate-ffi-type '(* char))))
(display (format #f "  translate-ffi-type (array int 10): ~S\n" (translate-ffi-type '(array int 10))))

;; 2. Declarators: define-c-struct, define-c-union, define-c-enum
(define-c-struct Basic_Point
  (x int)
  (y int))

(define-c-union Basic_Union
  (i int)
  (d double))

(define-c-enum Basic_Enum
  :enum-zero
  :enum-one
  (enum-five 5)
  :enum-six)

(display (format #f "  c-size Basic_Point: ~A\n" (c-size 'Basic_Point)))
(display (format #f "  c-size Basic_Union: ~A\n" (c-size 'Basic_Union)))
(display (format #f "  Basic_Enum: ~A, ~A, ~A, ~A\n" enum-zero enum-one enum-five enum-six))

;; 3. c-import
(c-import stress-add-points libtest "add_points" Basic_Point (Basic_Point Basic_Point))

;; 4. c.malloc, c.free, c.realloc, c.calloc
(let* ((p1 (c.malloc 8))
       (p2 (c.realloc p1 16)))
  (display (format #f "  c.malloc/realloc ptr: ~A\n" (c-pointer? p2)))
  (display (format #f "  c.realloc bounds check: ~A\n" (lext-bounds-check p2 16)))
  (c.free p2))

(let ((p (c.calloc 4 4)))
  (display (format #f "  c.calloc bounds check: ~A\n" (lext-bounds-check p 16)))
  (c.free p))

;; 4b. c.raw-malloc, c.raw-free, c.raw-realloc, c.raw-calloc
(let* ((p1 (c.raw-malloc 8))
       (p2 (c.raw-realloc p1 16)))
  (display (format #f "  c.raw-malloc/realloc ptr: ~A\n" (c-pointer? p2)))
  (display (format #f "  c.raw-realloc bounds check (should be false): ~A\n" (lext-bounds-check p2 16)))
  (c.raw-free p2))

(let ((p (c.raw-calloc 4 4)))
  (display (format #f "  c.raw-calloc bounds check (should be false): ~A\n" (lext-bounds-check p 16)))
  (c.raw-free p))

;; 4c. lext-register-bounds, lext-unregister-bounds
(let ((p (c.raw-malloc 8)))
  (lext-register-bounds p 8)
  (display (format #f "  lext-register-bounds check: ~A\n" (lext-bounds-check p 8)))
  (lext-unregister-bounds p)
  (display (format #f "  lext-unregister-bounds check (should be false): ~A\n" (lext-bounds-check p 8)))
  (c.raw-free p))

;; 5. internal-c-memcpy, internal-c-memset
(let ((buf1 (c.malloc 10))
      (buf2 (c.malloc 10)))
  (internal-c-memset buf1 65 10) ; fill with 'A'
  (internal-c-memcpy buf2 buf1 10)
  (display (format #f "  memset/memcpy check char: ~A\n" (ffi-deref buf2 'char)))
  (c.free buf1)
  (c.free buf2))

;; 6. internal-c-ptr+
(let* ((base (c.malloc 16))
       (offset-ptr (internal-c-ptr+ base 8)))
  (display (format #f "  ptr+ offset check: ~A\n" (not (eq? base offset-ptr))))
  (c.free base))

;; 7. c.deref, c.set!, c.addr
(let ((ptr (c.malloc 4)))
  (c.set! ptr 'int 999)
  (display (format #f "  c.set!/c.deref: ~A\n" (c.deref ptr 'int)))
  (display (format #f "  c.addr check: ~A\n" (pair? (c.addr (internal-c-tptr 'int ptr)))))
  (c.free ptr))

;; 8. c.@, c.=, c.&
(with-heap-alloc (pt Basic_Point)
  (c.= pt.x 123)
  (c.= pt.y 456)
  (display (format #f "  c.=@ x: ~A, y: ~A\n" (c.@ pt.x) (c.@ pt.y)))
  (let ((addr-val (c.& pt.y)))
    (display (format #f "  c.& type: ~A\n" (car addr-val)))))

;; 9. with-heap-alloc, with-alloc, with-c-string, with-c-array, with-c-string-array
(with-alloc (pt Basic_Point)
  (c.= pt.x 777)
  (display (format #f "  with-alloc: ~A\n" (c.@ pt.x))))

(with-c-string (s "Test string FFI")
  (display (format #f "  with-c-string: ~S\n" (c-string-from-ptr s))))

(with-c-array (arr int '(11 22 33))
  (display (format #f "  with-c-array [1]: ~A\n" (c.@ arr.1))))

(with-c-string-array (s-arr '("foo" "bar"))
  (display (format #f "  with-c-string-array: ~S\n" (c-string-array->list s-arr))))

;; 9b. Variadic C FFI call (printf)
(c-import stress-printf libc "printf" int (string) 1)
(let ((out (capture (stress-printf "Variadic: %s %d %f" "lext" 42 3.14))))
  (display (format #f "  variadic printf: ~S\n" out)))

;; 10. capture
(let ((out (capture (display "Stdout captured line!\n"))))
  (display (format #f "  capture output: ~S\n" out)))

;; 11. c.null-ptr?, c.null-ptr
(display (format #f "  null-ptr? (null-ptr): ~A\n" (c.null-ptr? (c.null-ptr))))
(display (format #f "  null-ptr? non-null: ~A\n" (c.null-ptr? 12345)))

;; 12. c.c-cast
(with-alloc (pt Basic_Point)
  (let ((casted (c.c-cast pt 'int)))
    (display (format #f "  c.c-cast type: ~A\n" (car casted)))))

;; 13. open-namespace, use-namespace & loop constructs
(use-namespace "c"
  (display (format #f "  use-namespace block (c.malloc): ~A\n" (defined? 'malloc))))

(open-namespace "basic")
(let ((loop-checked 0))
  (while (< loop-checked 3)
    (set! loop-checked (+ loop-checked 1)))
  (display (format #f "  while loop check: ~A\n" loop-checked)))

(let ((for-checked 0))
  (for (i 0 4)
    (set! for-checked (+ for-checked i)))
  (display (format #f "  for loop check: ~A\n" for-checked)))

(let ((foreach-checked ""))
  (foreach (x '("a" "b" "c"))
    (set! foreach-checked (string-append foreach-checked x)))
  (display (format #f "  foreach loop check: ~S\n" foreach-checked)))


;; ============================================================================
;; PART B: libnob.lext coverage
;; ============================================================================
(display "\n--- [PART B] Testing libnob.lext ---\n")

;; 1. Pointer arithmetic
(let* ((ptr (c.malloc 8))
       (addr (c-pointer->integer ptr))
       (ptr2 (integer->c-pointer addr))
       (ptr3 (c.raw-ptr+ ptr2 4)))
  (display (format #f "  Pointer conversions: ~A\n" (eq? ptr ptr2)))
  (display (format #f "  Pointer add offset: ~A\n" (not (eq? ptr2 ptr3))))
  (c.free ptr))

;; 2. Log API
(libnob.minimal-log-level-set! 0)
(display (format #f "  minimal-log-level: ~A\n" (libnob.minimal-log-level)))
(libnob.log 0 "Testing log output: ~A" "success")

;; 3. Command API & Render
(let ((cmd (libnob.cmd-new)))
  (libnob.cmd-append cmd "echo" "hello" "world")
  (display (format #f "  Rendered command: ~S\n" (libnob.cmd-render cmd)))
  
  ;; Sync and async command execution
  (display (format #f "  cmd-run sync: ~A\n" (libnob.cmd-run cmd)))
  (display (format #f "  cmd-run-async: ~A\n" (integer? (libnob.cmd-run-async cmd))))
  
  ;; Sync and async with reset
  (libnob.cmd-append cmd "echo" "reset-test")
  (display (format #f "  cmd-run-sync-and-reset: ~A\n" (libnob.cmd-run-sync-and-reset cmd)))
  
  (libnob.cmd-append cmd "echo" "async-reset-test")
  (let ((pid (libnob.cmd-run-async-and-reset cmd)))
    (display (format #f "  cmd-run-async-and-reset pid: ~A\n" (libnob.proc-wait pid))))
    
  (libnob.cmd-free cmd))

;; Command redirects
(let ((cmd (libnob.cmd-new))
      (redir (c.malloc 24)))
  (libnob.cmd-append cmd "echo" "redirect-test")
  (ffi-set! redir '(struct (pointer fdin) (pointer fdout) (pointer fderr)) '((fdin . ()) (fdout . ()) (fderr . ())))
  (display (format #f "  cmd-run-sync-redirect: ~A\n" (libnob.cmd-run-sync-redirect cmd redir)))
  (libnob.cmd-append cmd "echo" "redirect-async")
  (let ((pid (libnob.cmd-run-async-redirect cmd redir)))
    (display (format #f "  cmd-run-async-redirect pid: ~A\n" (libnob.proc-wait pid))))
  (libnob.cmd-free cmd)
  (c.free redir))

;; 4. File operations & temporary paths
(let ((temp-path "build/test_temp_file.txt"))
  (display (format #f "  write-entire-file: ~A\n" (libnob.write-entire-file temp-path "Hello Lext File System!")))
  (display (format #f "  file-exists: ~A\n" (libnob.file-exists temp-path)))
  (display (format #f "  read-entire-file: ~S\n" (libnob.read-entire-file temp-path)))
  (display (format #f "  get-file-type: ~A\n" (libnob.get-file-type temp-path)))
  
  ;; Copy and rename
  (display (format #f "  copy-file: ~A\n" (libnob.copy-file temp-path "build/test_temp_copy.txt")))
  (display (format #f "  rename: ~A\n" (libnob.rename "build/test_temp_copy.txt" "build/test_temp_renamed.txt")))
  
  ;; Path helpers
  (display (format #f "  path-name: ~S\n" (libnob.path-name temp-path)))
  (display (format #f "  temp-dir-name: ~S\n" (libnob.temp-dir-name temp-path)))
  (display (format #f "  temp-file-name: ~S\n" (libnob.temp-file-name temp-path)))
  (display (format #f "  temp-file-ext: ~S\n" (libnob.temp-file-ext temp-path)))
  
  (libnob.delete-file temp-path)
  (libnob.delete-file "build/test_temp_renamed.txt"))

(display (format #f "  get-current-dir-temp: ~S\n" (libnob.get-current-dir-temp)))
(display (format #f "  temp-running-executable-path: ~S\n" (libnob.temp-running-executable-path)))
(display (format #f "  nanos-since-unspecified-epoch: ~A\n" (libnob.nanos-since-unspecified-epoch)))
(display (format #f "  nprocs: ~A\n" (libnob.nprocs)))
(display (format #f "  read-entire-dir: ~A\n" (list? (libnob.read-entire-dir "stdlib"))))

;; Directory copy and walk
(libnob.mkdir-if-not-exists "build/test_dir")
(libnob.copy-directory-recursively "stdlib/basic" "build/test_dir")
(let ((walk-count 0))
  (libnob.walk-dir "build/test_dir" (lambda (p t l) (set! walk-count (+ walk-count 1)) #t))
  (display (format #f "  walk-dir walked ~A files/dirs\n" walk-count)))
;; Cleanup copied dir
(libnob.delete-file "build/test_dir/lib.lext")
(libnob.delete-file "build/test_dir")

;; String builder padding
(let ((sb (c.malloc 24)))
  (ffi-set! sb 'Nob_String_Builder '((items . ()) (count . 0) (capacity . 0)))
  (libnob.sb-pad-align sb 16)
  (let* ((sb-struct (ffi-deref sb 'Nob_String_Builder))
         (count (cdr (assoc 'count sb-struct))))
    (display (format #f "  sb-pad-align count: ~A\n" count)))
  (libnob.cmd-free sb))

;; 5. Processes wait & flush API
(let* ((procs (c.malloc 24)))
  (ffi-set! procs 'Nob_Procs '((items . ()) (count . 0) (capacity . 0)))
  ;; Add some dummy child process
  (let* ((cmd (libnob.cmd-new)))
    (libnob.cmd-append cmd "sleep" "0.1")
    (let ((pid (libnob.cmd-run-async-and-reset cmd)))
      (libnob.procs-append-with-flush procs pid 4)
      (display (format #f "  procs count after append: ~A\n" (libnob.da-count procs)))
      (display (format #f "  procs-wait-and-reset: ~A\n" (libnob.procs-wait-and-reset procs))))))

;; Pipes API
(let ((pipe-ptr (c.malloc 8)))
  (display (format #f "  pipe-create: ~A\n" (libnob.pipe-create pipe-ptr)))
  (let* ((pipe-struct (ffi-deref pipe-ptr 'Nob_Pipe))
         (read-fd (cdr (assoc 'read pipe-struct)))
         (write-fd (cdr (assoc 'write pipe-struct))))
    (display (format #f "    read fd: ~A, write fd: ~A\n" read-fd write-fd))
    (libnob.fd-close read-fd)
    (libnob.fd-close write-fd))
  (c.free pipe-ptr))

;; Chains API
(let ((chain (c.calloc 1 40))
      (cmd (libnob.cmd-new)))
  (libnob.cmd-append cmd "echo" "chain-hello")
  (display (format #f "  chain-begin: ~A\n" (libnob.chain-begin chain)))
  (display (format #f "  chain-cmd: ~A\n" (libnob.chain-cmd chain cmd :err2out #t :dont-reset #t)))
  (display (format #f "  chain-end: ~A\n" (libnob.chain-end chain :max-procs 4)))
  (libnob.cmd-free cmd)
  (c.free chain))

;; Directory iterator API
(let ((dir-ent (c.malloc 32))) ; size of Nob_Dir_Entry
  (display (format #f "  dir-entry-open: ~A\n" (libnob.dir-entry-open "stdlib" dir-ent)))
  (display (format #f "  dir-entry-next: ~A\n" (libnob.dir-entry-next dir-ent)))
  (libnob.dir-entry-close (ffi-deref dir-ent 'Nob_Dir_Entry))
  (c.free dir-ent))

;; 6. String Views API
(let* ((sv1 (libnob.sv-from-cstr "   Trimmed SV!   "))
       (sv2 (libnob.sv-from-parts (cdr (assoc 'data sv1)) (cdr (assoc 'count sv1))))
       (trimmed (libnob.sv-trim sv2))
       (left (libnob.sv-trim-left sv1))
       (right (libnob.sv-trim-right sv1)))
  (display (format #f "  sv->string: ~S\n" (libnob.sv->string trimmed)))
  (display (format #f "  sv-eq: ~A\n" (libnob.sv-eq sv1 sv2)))
  (display (format #f "  sv-starts-with: ~A\n" (libnob.sv-starts-with sv1 (libnob.sv-from-cstr "   "))))
  (display (format #f "  sv-ends-with: ~A\n" (libnob.sv-ends-with sv1 (libnob.sv-from-cstr "   "))))
  (display (format #f "  sv-ends-with-cstr: ~A\n" (libnob.sv-ends-with-cstr sv1 "   "))))

;; String View Chopping
(let* ((sv (libnob.sv-from-cstr "foo:bar:baz"))
       (sv-ptr (c.malloc 16)))
  (ffi-set! sv-ptr 'Nob_String_View sv)
  (let* ((chopped1 (libnob.sv-chop-left sv-ptr 4))
         (chopped2 (libnob.sv-chop-right sv-ptr 4)))
    (display (format #f "  sv-chop-left: ~S\n" (libnob.sv->string chopped1)))
    (display (format #f "  sv-chop-right: ~S\n" (libnob.sv->string chopped2))))
  
  (ffi-set! sv-ptr 'Nob_String_View sv)
  (let ((chopped3 (libnob.sv-chop-by-delim sv-ptr #\:)))
    (display (format #f "  sv-chop-by-delim: ~S\n" (libnob.sv->string chopped3))))
    
  (ffi-set! sv-ptr 'Nob_String_View sv)
  (display (format #f "  sv-chop-prefix: ~A\n" (libnob.sv-chop-prefix sv-ptr (libnob.sv-from-cstr "foo"))))
  (display (format #f "  sv-chop-suffix: ~A\n" (libnob.sv-chop-suffix sv-ptr (libnob.sv-from-cstr "baz"))))
  (c.free sv-ptr))

;; 7. Temp Allocator API
(libnob.temp-reset)
(let* ((checkpoint (libnob.temp-save))
       (str1 (libnob.temp-strdup "Temp allocated string"))
       (str2 (libnob.temp-strndup "Temp limit string" 10))
       (raw-buf (libnob.temp-alloc 100)))
  (display (format #f "  temp-strdup: ~S\n" str1))
  (display (format #f "  temp-strndup: ~S\n" str2))
  (display (format #f "  temp-alloc ptr: ~A\n" (c-pointer? raw-buf)))
  (libnob.temp-rewind checkpoint))

;; 8. Dynamic Arrays API
(let ((da (c.malloc 24)))
  (libnob.da-set! da '((items . ()) (count . 0) (capacity . 0)))
  (libnob.da-reserve da 10 4) ; reserve for 10 ints
  (libnob.da-append da 100 int)
  (libnob.da-append da 200 int)
  (display (format #f "  da-items ptr: ~A\n" (c-pointer? (libnob.da-items da))))
  (display (format #f "  da-count: ~A\n" (libnob.da-count da)))
  (display (format #f "  da-capacity: ~A\n" (libnob.da-capacity da)))
  (display (format #f "  da-first: ~A\n" (libnob.da-first da 'int)))
  (display (format #f "  da-last: ~A\n" (libnob.da-last da 'int)))
  (display (format #f "  da-pop: ~A\n" (libnob.da-pop da 'int)))
  (libnob.da-free da)
  (c.free da))

;; 9. basic.shift
(let ((lst '("x" "y" "z")))
  (let ((val (basic.shift lst)))
    (display (format #f "  basic.shift first: ~S\n" val))
    (display (format #f "  basic.shift remainder: ~S\n" lst))))

;; 10. Rebuild dependencies checks
(display (format #f "  needs-rebuild: ~A\n" (libnob.needs-rebuild "build/lext" '("src/main.c" "src/nob.c"))))
(display (format #f "  needs-rebuild?: ~A\n" (libnob.needs-rebuild? "build/lext" "src/main.c")))

;; 11. File Descriptors API
(let ((fd (libnob.fd-open-for-write "build/test_fd_stress.txt")))
  (display (format #f "  fd-open-for-write: ~A\n" (>= fd 0)))
  (libnob.fd-close fd))
(let ((fd (libnob.fd-open-for-read "build/test_fd_stress.txt")))
  (display (format #f "  fd-open-for-read: ~A\n" (>= fd 0)))
  (libnob.fd-close fd))
(libnob.delete-file "build/test_fd_stress.txt")

;; ============================================================================
;; PART C: Public Bounds Checking API Tests
;; ============================================================================
(display "\n--- [PART C] Testing Public Bounds Checking API ---\n")

(define-macro (assert-error expr)
  `(let ((has-error #f))
     (catch #t
       (lambda ()
         ,expr)
       (lambda (tag info)
         (set! has-error #t)))
     (if (not has-error)
         (error (format #f "Expression failed to throw error: ~S" ',expr))
         (display (format #f "  Expected error caught successfully for: ~S\n" ',expr)))))

(let* ((p-tracked (c.malloc 10))
       (p-raw (c.raw-malloc 100)))
  ;; 1. Check registered sizes
  (display (format #f "  registered size of tracked ptr: ~A\n" (lext-registered-size p-tracked)))
  (display (format #f "  registered size of raw ptr (should be -1): ~A\n" (lext-registered-size p-raw)))
  
  ;; 2. Test c.memset
  (c.memset p-tracked 65 10) ; okay
  (assert-error (c.memset p-tracked 65 11)) ; error
  (c.memset p-raw 65 100) ; okay (raw pointer, no bounds check)
  
  ;; 3. Test c.memcpy
  (c.memcpy p-tracked p-tracked 5) ; okay
  (assert-error (c.memcpy p-tracked p-tracked 11)) ; error (dest/src out of bounds)
  (c.memcpy p-raw p-raw 50) ; okay (raw pointer, no bounds check)
  
  ;; 4. Test c.ptr+
  (let ((offset-ptr (c.ptr+ p-tracked 4)))
    (display (format #f "  c.ptr+ offset registered size: ~A\n" (lext-registered-size offset-ptr)))
    (c.memset offset-ptr 66 6) ; okay (4 + 6 = 10)
    (assert-error (c.memset offset-ptr 66 7))) ; error (4 + 7 = 11 > 10)
    
  (assert-error (c.ptr+ p-tracked 11)) ; error (offset out of bounds)
  (assert-error (c.ptr+ p-tracked -1)) ; error (offset out of bounds)
  
  ;; 5. Test c.deref and c.set! (and c.@ / c.=)
  (define-c-struct Test_Point
    (x int)
    (y int))
    
  (let ((pt (c.c-cast p-tracked 'Test_Point)))
    (c.set! pt 'Test_Point 123 'x) ; okay
    (c.set! pt 'Test_Point 456 'y) ; okay
    (display (format #f "  c.deref x: ~A, y: ~A\n" (c.deref pt 'Test_Point 'x) (c.deref pt 'Test_Point 'y)))
    
    (let ((pt-out (c.ptr+ pt 4))) ; remaining size = 6. Test_Point needs 8 bytes.
      (assert-error (c.deref pt-out 'Test_Point 'y)))) ; error (y is at offset 4 of pt-out, needing 4 bytes -> total 8 bytes, but remaining size is 6)
      
  ;; 6. Test raw variants (c.raw-memcpy, c.raw-memset, c.raw-ptr+)
  (c.raw-memset p-raw 67 50)
  (c.raw-memcpy p-raw p-raw 50)
  (let ((offset-raw (c.raw-ptr+ p-raw 50)))
    (display (format #f "  c.raw-ptr+ registered size (should be -1): ~A\n" (lext-registered-size offset-raw)))
    (c.raw-memset offset-raw 68 10))

  ;; 7. Test prefix-consistent aliases (c.tptr, c.size, etc.)
  (let ((pt-tptr (c.tptr 'Test_Point p-tracked)))
    (display (format #f "  c.tptr?: ~A\n" (c.tptr? pt-tptr)))
    (display (format #f "  c.tptr-type: ~A\n" (c.tptr-type pt-tptr)))
    (display (format #f "  c.tptr-ptr check: ~A\n" (c-pointer? (c.tptr-ptr pt-tptr))))
    (display (format #f "  c.size: ~A\n" (c.size 'Test_Point))))

  (let ((str-ptr (c.string->c-string "Hello consistent!")))
    (display (format #f "  c.string-from-ptr: ~S\n" (c.string-from-ptr str-ptr)))
    (c.free str-ptr))

  ;; 8. Test prefix-consistent macros (c.with-alloc, c.with-c-string, etc.)
  (c.with-alloc (pt-ns Test_Point)
    (c.set! pt-ns 'Test_Point 999 'x)
    (display (format #f "  c.with-alloc: ~A\n" (c.deref pt-ns 'Test_Point 'x))))

  (c.with-c-string (s-ns "Namespaced string FFI")
    (display (format #f "  c.with-c-string: ~S\n" (c.string-from-ptr s-ns))))

  (c.with-c-array (arr-ns int '(44 55 66))
    (display (format #f "  c.with-c-array [1]: ~A\n" (c.deref arr-ns 'int 1))))

  (c.with-c-string-array (s-arr-ns '("ns1" "ns2"))
    (display (format #f "  c.with-c-string-array: ~S\n" (c.string-array->list s-arr-ns))))

  (let ((out-ns (basic.capture (display "Stdout consistent!\n"))))
    (display (format #f "  basic.capture output: ~S\n" out-ns)))

  (c.free p-tracked)
  (c.raw-free p-raw))

;; 12. clean up helper dynamic lib
(ffi-close libtest)
(libnob.delete-file "test/libtest.so")

(display "\nAll standard library functions checked and passed successfully!\n")
