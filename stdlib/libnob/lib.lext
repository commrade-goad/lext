(use "stdlib/basic" "stdlib/c")

(export minimal-log-level minimal-log-level-ptr minimal-log-level-set!
        log cmd-new cmd-append cmd-free cmd-run delete-file
        mkdir-if-not-exists file-exists copy-file
        copy-directory-recursively read-entire-file write-entire-file
        get-file-type rename path-name get-current-dir-temp
        set-current-dir temp-dir-name temp-file-name temp-file-ext
        temp-running-executable-path nanos-since-unspecified-epoch
        nprocs read-entire-dir sb-pad-align proc-wait procs-wait
        procs-flush pipe-create dir-entry-open dir-entry-next
        dir-entry-close sv-from-cstr sv-from-parts sv-trim sv-trim-left
        sv-trim-right sv-chop-left sv-chop-right sv-chop-by-delim
        sv-chop-prefix sv-chop-suffix sv-eq sv-starts-with sv-ends-with
        sv-ends-with-cstr sv->string temp-reset temp-save temp-rewind
        temp-alloc temp-strdup temp-strndup da-items da-count
        da-capacity da-first da-last da-pop da-set! da-reserve da-append da-free walk-dir walk-dir-opt
        walk-dir-opt-default walk-dir-opt-userdata walk-dir-opt-recursive
        walk-dir-opt-log-level walk-dir-opt-recursive-set!
        walk-dir-opt-log-level-set! walk-entry walk-entry-name
        walk-entry-error walk-entry-posix-dir walk-entry-posix-ent
        needs-rebuild? needs-rebuild fd-open-for-write fd-open-for-read fd-close
        cmd-render cmd-run-async cmd-run-async-and-reset
        cmd-run-async-redirect cmd-run-async-redirect-and-reset
        cmd-run-sync cmd-run-sync-and-reset cmd-run-sync-redirect
        cmd-run-sync-redirect-and-reset procs-wait-and-reset
        procs-append-with-flush chain-begin chain-cmd chain-end)

(define internal-libnob (ffi-open #f))
(define *libnob-env* (curlet))

(define (internal-nob-struct-val val type)
  (cond
    ((c-pointer? val) (ffi-deref val type))
    ((and (pair? val) (c-pointer? (cdr val))) (ffi-deref (cdr val) type))
    (else val)))

;; C Struct Type Registrations
(ffi-typedef 'Nob_Cmd
             '(struct (pointer items)
                      (ulong count)
                      (ulong capacity)))

(ffi-typedef 'Nob_Procs
             '(struct (pointer items)
                      (ulong count)
                      (ulong capacity)))

(ffi-typedef 'Nob_Cmd_Opt
             '(struct (pointer async)
                      (ulong max_procs)
                      (uchar dont_reset)
                      (string stdin_path)
                      (string stdout_path)
                      (string stderr_path)))

(ffi-typedef 'Nob_String_Builder
             '(struct (pointer items)
                      (ulong count)
                      (ulong capacity)))

(ffi-typedef 'Nob_File_Paths
             '(struct (pointer items)
                      (ulong count)
                      (ulong capacity)))

(ffi-typedef 'Nob_Dynamic_Array
             '(struct (pointer items)
                      (ulong count)
                      (ulong capacity)))

(ffi-typedef 'Nob_String_View
             '(struct (ulong count)
                      (pointer data)))

(ffi-typedef 'Nob_Pipe
             '(struct (int read)
                      (int write)))

(ffi-typedef 'Nob_Chain
             '(struct (int fdin)
                      (Nob_Cmd cmd)
                      (uchar err2out)))

(ffi-typedef 'Nob_Chain_Begin_Opt
             '(struct (string stdin_path)))

(ffi-typedef 'Nob_Chain_Cmd_Opt
             '(struct (uchar err2out)
                      (uchar dont_reset)))

(ffi-typedef 'Nob_Chain_End_Opt
             '(struct (pointer async)
                      (ulong max_procs)
                      (string stdout_path)
                      (string stderr_path)))

(ffi-typedef 'Nob_Dir_Entry
             '(struct (pointer name)
                      (uchar error)
                      (pointer posix_dir)
                      (pointer posix_ent)))

(ffi-typedef 'Nob_Cmd_Redirect
             '(struct (pointer fdin)
                      (pointer fdout)
                      (pointer fderr)))

